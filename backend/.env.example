# ─── Supabase (Phase 2+ — optional in Phase 1) ──────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ─── App ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development                 # development | production
# Comma-separated. Include your Expo dev URLs (Metro + LAN/tunnel).
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# ─── yt-dlp ─────────────────────────────────────────────────────────────────
YTDLP_AUDIO_FORMAT=m4a                  # preferred container; we still take bestaudio direct
YTDLP_AUDIO_QUALITY=0                   # 0 = best
YTDLP_TIMEOUT_SECONDS=15                # P4: yt-dlp can take 5-12s on cold starts

# ─── Recommendations / region ───────────────────────────────────────────────
DEFAULT_COUNTRY=IN

# ─── Rate limiting (enforced in Phase 4; values read but lenient in Phase 1) ─
STREAM_RATE_LIMIT_PER_MINUTE=30
STREAM_RATE_LIMIT_IP_PER_MINUTE=60
SEARCH_RATE_LIMIT_PER_MINUTE=60

# ─── Observability ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=text                         # json | text  (text for local dev, json in prod)
