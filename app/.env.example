# Backend API base URL (include the /api/v1 prefix).
# Use your machine's LAN IP — NOT localhost — so a physical device can reach it.
# Find it with `ipconfig` (Windows) / `ifconfig` (mac/linux).
#
# Examples:
#   EXPO_PUBLIC_API_URL=http://192.168.1.20:8000/api/v1   # local dev (LAN)
#   EXPO_PUBLIC_API_URL=https://bop-backend.up.railway.app/api/v1  # production
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1

# ─── Supabase (Phase 2 auth) ─────────────────────────────────────────────────
# Dashboard → Project Settings → API.
# The anon key is a PUBLIC client key (safe in the app bundle). Never put the
# service-role key here — that lives only in the backend.
EXPO_PUBLIC_SUPABASE_URL=https://jqamxnplyvtjxwztumma.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
